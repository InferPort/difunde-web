---
import LandingLayout from '../layouts/LandingLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Capabilities from '../components/Capabilities.astro';
import Benefits from '../components/Benefits.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<LandingLayout
  title="Difunde — Comunicación empresarial multicanal"
  description="WhatsApp, Email y automatizaciones en una sola plataforma. Campañas masivas, chat en vivo y API para integraciones."
>
  <Header />
  <main class="overflow-x-hidden w-full max-w-full">
    <Hero />
    <TrustBar />
    <Capabilities />
    <Benefits />
    <HowItWorks />
    <Pricing />
    <FAQ />
  </main>
  <Footer />
</LandingLayout>

<script>
  import '../scripts/animations.js';
</script>
