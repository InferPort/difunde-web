---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Página no encontrada — Difunde"
  description="La página que buscas no existe. Regresa al inicio de Difunde."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <div class="text-8xl font-extrabold text-brand-500/20 tracking-tight">404</div>
    <h1 class="text-2xl font-bold text-ink mt-4">Página no encontrada</h1>
    <p class="text-muted mt-2 max-w-md">
      La página que buscas no existe o fue movida.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-brand-500 text-white font-semibold text-sm hover:bg-brand-600 transition-colors no-underline"
    >
      Volver al inicio
    </a>
  </div>
</LandingLayout>
