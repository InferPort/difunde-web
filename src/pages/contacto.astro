---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout
  title="Contacto — Difunde"
  description="Contáctanos para conocer cómo Difunde puede transformar tu comunicación empresarial."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <h1 class="text-3xl font-extrabold text-ink tracking-tight">Contacto</h1>
    <p class="text-muted mt-4 max-w-lg">
      Escríbenos a <a href="mailto:hola@difunde.co" class="text-brand-500 no-underline">hola@difunde.co</a> y te responderemos en breve.
    </p>
    <a href="/" class="mt-6 text-sm text-brand-500 hover:text-brand-600 no-underline font-semibold">
      ← Volver al inicio
    </a>
  </div>
</LandingLayout>
