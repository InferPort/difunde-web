---

---

<section class="relative min-h-[90dvh] flex items-center overflow-hidden">
  <div class="hero-parallax absolute inset-0 pointer-events-none">
    <span class="hero-orb absolute top-[12%] left-[8%] w-[550px] h-[550px] rounded-full bg-brand-500/10 blur-[130px]"></span>
    <span class="hero-orb absolute top-[25%] right-[3%] w-[450px] h-[450px] rounded-full bg-accent-500/6 blur-[110px]"></span>
    <span class="hero-orb absolute bottom-[15%] left-[35%] w-[400px] h-[400px] rounded-full bg-brand-500/5 blur-[100px]"></span>
    <span class="hero-orb absolute top-[8%] right-[20%] w-[300px] h-[300px] rounded-full bg-amber-500/4 blur-[80px]"></span>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_white_0%,_transparent_70%)]"></div>
  </div>

  <div class="container relative z-10 pt-36 pb-20 md:pt-44 md:pb-28">
    <div class="max-w-5xl mx-auto">
      <div class="md:text-center">
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-brand-200 bg-white/70 text-brand-600 text-xs font-semibold mb-6 backdrop-blur-md animate-fade-up">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse-glow"></span>
          Plataforma multicanal de mensajería empresarial
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-[4rem] font-extrabold tracking-[-0.03em] text-ink leading-[1.06] text-balance max-w-4xl md:mx-auto animate-fade-up" style="animation-delay: 0.1s">
          La comunicación que tu empresa necesita,<br class="hidden sm:block" />
          <span class="text-brand-500">en un solo lugar</span>
        </h1>

        <p class="mt-5 text-lg md:text-xl text-muted max-w-2xl md:mx-auto text-balance animate-fade-up" style="animation-delay: 0.15s">
          WhatsApp Business API, Email masivo, chat en vivo y automatizaciones.
          Una plataforma. Sin integraciones costosas.
        </p>

        <div class="mt-3 flex items-center gap-2 justify-center text-sm text-muted animate-fade-up" style="animation-delay: 0.2s">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span>Únete a <strong class="text-ink">15,000+</strong> empresas en Latinoamérica</span>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up" style="animation-delay: 0.25s">
          <a
            href="#precios"
            class="btn-press btn-arrow inline-flex items-center px-8 py-3.5 rounded-full bg-brand-500 text-white text-sm font-semibold no-underline hover:bg-brand-600 transition-colors shadow-lg shadow-brand-500/25"
          >
            Empezar ahora
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#beneficios"
            class="btn-press inline-flex items-center px-8 py-3.5 rounded-full border border-[oklch(0.88_0.005_0)] bg-white/70 text-ink text-sm font-semibold no-underline hover:bg-surface backdrop-blur-sm transition-colors"
          >
            Ver funcionalidades
          </a>
        </div>
      </div>

      <div class="mt-16 md:mt-20 grid md:grid-cols-3 gap-4 max-w-4xl mx-auto animate-fade-up" style="animation-delay: 0.35s">
        <div class="flex items-start gap-3 p-4 rounded-xl bg-white/50 backdrop-blur-sm border border-[oklch(0.92_0.005_0)]">
          <div class="w-8 h-8 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-ink">Cifrado de extremo a extremo</p>
            <p class="text-xs text-muted">Tus datos seguros en todo momento</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl bg-white/50 backdrop-blur-sm border border-[oklch(0.92_0.005_0)]">
          <div class="w-8 h-8 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-ink">99.9% disponibilidad</p>
            <p class="text-xs text-muted">SLA garantizado en todos los planes</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl bg-white/50 backdrop-blur-sm border border-[oklch(0.92_0.005_0)]">
          <div class="w-8 h-8 rounded-lg bg-brand-100 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-ink">Sin infraestructura propia</p>
            <p class="text-xs text-muted">Nosotros gestionamos la tecnología</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
