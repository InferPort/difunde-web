---

const year = new Date().getFullYear();
---

<footer class="border-t border-[oklch(0.92_0.003_0)] py-16">
  <div class="container">
    <div class="grid md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 no-underline mb-4">
          <div class="w-7 h-7 rounded-md bg-brand-500 flex items-center justify-center text-white font-bold text-xs">
            D
          </div>
          <span class="text-base font-bold text-ink tracking-tight">difunde</span>
        </a>
        <p class="text-sm text-muted max-w-sm">
          Plataforma multicanal de mensajería empresarial. WhatsApp, Email y automatizaciones en un solo lugar.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-ink uppercase tracking-widest mb-4">Producto</h4>
        <ul class="space-y-2.5">
          <li><a href="#beneficios" class="text-sm text-muted hover:text-ink transition-colors no-underline">Beneficios</a></li>
          <li><a href="#como-funciona" class="text-sm text-muted hover:text-ink transition-colors no-underline">Cómo funciona</a></li>
          <li><a href="#precios" class="text-sm text-muted hover:text-ink transition-colors no-underline">Precios</a></li>
          <li><a href="#precios" class="text-sm text-muted hover:text-ink transition-colors no-underline">Precios</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold text-ink uppercase tracking-widest mb-4">Legal</h4>
        <ul class="space-y-2.5">
          <li><a href="/privacidad" class="text-sm text-muted hover:text-ink transition-colors no-underline">Privacidad</a></li>
          <li><a href="/terminos" class="text-sm text-muted hover:text-ink transition-colors no-underline">Términos</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-[oklch(0.92_0.003_0)] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted">&copy; {year} Difunde. Todos los derechos reservados.</p>
