<section id="precios" class="py-24 md:py-32">
  <div class="container">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-xs font-semibold text-brand-500 uppercase tracking-widest mb-4">Precios</div>
      <h2 class="text-3xl md:text-4xl font-extrabold text-ink tracking-tight">
        Planes para cada etapa de tu empresa
      </h2>
      <p class="mt-4 text-muted text-lg">
        Desde PyMEs hasta grandes volúmenes. Sin sorpresas.
      </p>
    </div>

    <div class="mt-12 flex items-center justify-center gap-3" id="pricing-toggle">
      <span class="text-sm font-medium text-ink">Mensual</span>
      <button
        class="relative w-12 h-6 rounded-full bg-brand-200 cursor-pointer transition-colors hover:bg-brand-300"
        data-toggle
        aria-label="Cambiar a facturación anual"
      >
        <span class="absolute top-0.5 left-0.5 w-5 h-5 rounded-full bg-white shadow-sm transition-transform" data-knob></span>
      </button>
      <span class="text-sm font-medium text-muted">Anual</span>
      <span class="ml-1 px-2 py-0.5 rounded-full bg-brand-100 text-brand-600 text-[10px] font-bold">Ahorra 20%</span>
    </div>

    <div class="mt-10 grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      <article class="pricing-card rounded-2xl border border-[oklch(0.92_0.003_0)] bg-surface p-8 flex flex-col card-hover">
        <h3 class="text-lg font-bold text-ink">Gratuito</h3>
        <p class="mt-1 text-sm text-muted">Para empezar sin costo</p>
        <div class="mt-6 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-ink">$0</span>
          <span class="text-muted text-sm">USD/mes</span>
        </div>
        <ul class="mt-8 space-y-3 flex-1">
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Hasta 500 contactos</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>1 canal WhatsApp o Email</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Hasta 10 plantillas</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Panel de estadísticas</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>500 mensajes / mes</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-muted">
            <svg class="w-4 h-4 text-muted mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            <span>Automatizaciones avanzadas</span>
          </li>
        </ul>
        <a
          href="https://dashboard.difunde.co/auth"
          class="btn-press mt-8 inline-flex items-center justify-center px-4 py-2.5 rounded-lg border border-brand-200 text-brand-600 text-sm font-semibold no-underline hover:bg-brand-50 transition-colors text-center"
        >
          Crear cuenta gratis
        </a>
      </article>

      <article class="pricing-card rounded-2xl border-2 border-brand-500 bg-surface p-8 flex flex-col relative card-hover reveal-delay-1">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-brand-500 text-white text-[10px] font-bold uppercase tracking-wider">
          Más popular
        </div>
        <h3 class="text-lg font-bold text-ink">Profesional</h3>
        <p class="mt-1 text-sm text-muted">Para empresas en crecimiento</p>
        <div class="mt-6 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-ink" data-price data-monthly="49" data-yearly="39">49</span>
          <span class="text-muted text-sm">USD/mes</span>
        </div>
        <ul class="mt-8 space-y-3 flex-1">
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Hasta 5,000 contactos</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>WhatsApp + Email (ambos canales)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Automatizaciones visuales ilimitadas</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>API Keys para integraciones</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Auditoría con hash chain</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>5,000 mensajes / mes incluidos</span>
          </li>
        </ul>
        <a
          href="https://dashboard.difunde.co/auth"
          class="btn-press mt-8 inline-flex items-center justify-center px-4 py-2.5 rounded-lg bg-brand-500 text-white text-sm font-semibold no-underline hover:bg-brand-600 transition-colors shadow-lg shadow-brand-500/20 text-center"
        >
          Elegir Profesional
        </a>
      </article>

      <article class="pricing-card rounded-2xl border border-[oklch(0.92_0.003_0)] bg-surface p-8 flex flex-col card-hover reveal-delay-2">
        <h3 class="text-lg font-bold text-ink">Enterprise</h3>
        <p class="mt-1 text-sm text-muted">Para grandes volúmenes</p>
        <div class="mt-6 flex items-baseline gap-1">
          <span class="text-4xl font-extrabold text-ink">$149</span>
          <span class="text-muted text-sm">USD/mes</span>
        </div>
        <ul class="mt-8 space-y-3 flex-1">
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Contactos ilimitados</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Multi-tenancy con aislamiento</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>SLA de disponibilidad 99.9%</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>On-premise / nube privada</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Gerente de cuenta dedicado</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-ink">
            <svg class="w-4 h-4 text-brand-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            <span>Integración personalizada</span>
          </li>
        </ul>
        <a
          href="https://dashboard.difunde.co/contacto"
          class="btn-press mt-8 inline-flex items-center justify-center px-4 py-2.5 rounded-lg border border-accent-300 text-accent-600 text-sm font-semibold no-underline hover:bg-accent-50 transition-colors text-center"
        >
          Cotizar
        </a>
      </article>
    </div>
  </div>
</section>

<script>
  const toggle = document.querySelector('[data-toggle]');
  const knob = document.querySelector('[data-knob]');
  const prices = document.querySelectorAll('[data-price]');

  if (toggle && knob && prices.length) {
    let isAnnual = false;

    toggle.addEventListener('click', () => {
      isAnnual = !isAnnual;
      knob.style.transform = isAnnual ? 'translateX(24px)' : 'translateX(0)';

      prices.forEach((el) => {
        const monthly = el.dataset.monthly;
        const yearly = el.dataset.yearly;
        if (monthly && yearly) {
          el.textContent = isAnnual ? yearly : monthly;
        }
      });
    });
  }
</script>
